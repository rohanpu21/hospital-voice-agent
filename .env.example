# ════════════════════════════════════════════════════════════
#  Hospital Voice Agent — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════

# ── Groq API (free tier available — get key at console.groq.com) ─────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Sarvam AI (Indian STT/TTS — get key at sarvam.ai) ───────────────────────
SARVAM_API_KEY=your_sarvam_subscription_key_here

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=8000

# ── Optional: Fast2SMS for appointment SMS confirmations ─────────────────────
# FAST2SMS_API_KEY=your_fast2sms_key_here

# ── Ngrok (auto-tunnel for Exotel webhooks) ──────────────────────────────────
# Leave blank to auto-start ngrok tunnel on `python main.py`
# Set a fixed URL if you have a paid ngrok plan with a custom domain.
# NGROK_URL=https://your-subdomain.ngrok-free.app

# ── NOTES ─────────────────────────────────────────────────────────────────────
# Google Calendar credentials are stored as JSON files per hospital in config/
# See config/hospitals.json for the credentials_file path for each hospital.
# Each hospital needs its own Google Service Account credentials JSON file.
#
# EXOTEL SETUP:
# 1. Sign up at exotel.com, get an Indian virtual number
# 2. Create a Passthru Applet with webhook URL:
#      https://<ngrok-url>/exotel/incoming?hospital_id=aiims-bbsr-001
# 3. Run `python main.py` — it auto-starts ngrok and prints the URL
